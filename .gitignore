# Node.js / Angular Gitignore
# ------------------------------------------
# Dependencies
node_modules/
/frontend/node_modules/

# Angular cache and build output
.angular/
/frontend/.angular/
dist/
/frontend/dist/

# Env files
.env
.env.*
!.env.example
/frontend/.env
/frontend/.env.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

